{
  "name": "@wanshi-kg/wanshi",
  "version": "0.1.0",
  "description": "Local-first CLI that turns files, code, PDFs, audio and transcripts into a provenance-tracked knowledge graph — via local Ollama or any OpenAI-compatible LLM.",
  "keywords": [
    "knowledge-graph",
    "knowledge-graph-extraction",
    "entity-extraction",
    "relation-extraction",
    "ner",
    "llm",
    "ollama",
    "openai",
    "rag",
    "mcp",
    "provenance",
    "temporal-knowledge-graph",
    "cli",
    "typescript"
  ],
  "main": "./dist/index.js",
  "bin": {
    "wanshi": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wanshi-kg/wanshi.git"
  },
  "homepage": "https://github.com/wanshi-kg/wanshi#readme",
  "bugs": {
    "url": "https://github.com/wanshi-kg/wanshi/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "ts-node ./src/cli/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "build": "tsc && node scripts/copy-assets.js",
    "prepublishOnly": "npm run build && npm test",
    "benchmark": "ts-node scripts/benchmark.ts",
    "classifier-eval": "ts-node scripts/classifier-eval.ts"
  },
  "author": "Alex Sabaka",
  "license": "MIT",
  "nodemonConfig": {
    "exec": "ts-node ./src/cli/index.ts",
    "ext": "*.ts,*.js,*.json",
    "ignore": [
      "**/test/**",
      "**/docs/**"
    ]
  },
  "dependencies": {
    "@citation-js/core": "^0.7.21",
    "@citation-js/plugin-bibtex": "^0.7.21",
    "@huggingface/transformers": "^3.5.2",
    "@langchain/core": "^0.3.57",
    "@langchain/textsplitters": "^0.1.0",
    "@types/node": "^22.7.4",
    "@types/sql.js": "^1.4.11",
    "@wanshi-kg/outlion": "^1.0.1",
    "adm-zip": "^0.5.17",
    "chalk": "^4.1.2",
    "cheerio": "^1.1.0",
    "chokidar": "^4.0.3",
    "cli-highlight": "^2.1.11",
    "commander": "^12.1.0",
    "detect-file-encoding-and-language": "^2.4.0",
    "dree": "^5.1.5",
    "exifr": "^7.1.3",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "glob": "^11.0.2",
    "handlebars": "^4.7.8",
    "highlight.js": "^11.10.0",
    "html-to-text": "^9.0.5",
    "iconv": "^3.0.1",
    "iconv-lite": "^0.6.3",
    "js-yaml": "^4.1.0",
    "jsonrepair": "^3.14.0",
    "mailparser": "^3.9.10",
    "minimatch": "^10.0.1",
    "nodejs-whisper": "^0.2.9",
    "officeparser": "^5.1.1",
    "ollama": "^0.5.16",
    "openai": "^6.42.0",
    "pdf-to-png-converter": "^3.18.0",
    "pdf2json": "^3.1.6",
    "pretty-format": "^29.7.0",
    "readline-sync": "^1.4.10",
    "rtf-parser": "^1.3.3",
    "rtf-stream-parser": "^3.8.0",
    "sql.js": "^1.14.1",
    "tesseract.js": "^7.0.0",
    "ts-graphviz": "^2.1.6",
    "tslog": "^4.9.3",
    "typescript": "^5.6.2",
    "zod": "^3.25.48",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/html-to-text": "^9.0.4",
    "@types/iconv": "^3.0.4",
    "@types/jest": "^29.5.13",
    "@types/js-yaml": "^4.0.9",
    "@types/mailparser": "^3.4.6",
    "@types/readline-sync": "^1.4.8",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "ts-jest": "^29.2.5"
  }
}
