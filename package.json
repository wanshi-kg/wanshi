{
  "name": "wanshi",
  "version": "1.0.0",
  "description": "Knowledge Graph Generator",
  "main": "./src/index.ts",
  "bin": {
    "wanshi": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexSabaka/wanshi.git"
