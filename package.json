    "@langchain/textsplitters": "^0.1.0",
    "@types/node": "^22.7.4",
    "chalk": "^4.1.2",
    "cheerio": "^1.1.0",
    "chokidar": "^4.0.3",
    "cli-highlight": "^2.1.11",
    "commander": "^12.1.0",
    "document-outline-gen": "file:../document-outline-gen",
    "dree": "^5.1.5",
