# Gmail API Configuration (OAuth2)
# No app-specific password needed!
# Instead, use OAuth2 authentication:
# 1. Create a Google Cloud project: https://console.cloud.google.com
# 2. Enable Gmail API
# 3. Create OAuth 2.0 Desktop credentials
# 4. Download credentials as JSON
# 5. Save as credentials.json in project root
# 6. Run: npm run gmail:auth
# This will create token.json for you automatically

# Google OAuth2 Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# IMAP Configuration (Legacy - not used with Gmail API)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-email@gmail.com
IMAP_PASSWORD=your-app-password

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Telegram Configuration
# 1. Create a bot with @BotFather on Telegram
# 2. Copy the token from BotFather
# 3. Get your user ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_USER_ID=your-user-id-here
# Email Filtering Configuration
# Process emails only from last N hours (default: 24)
EMAIL_MAX_AGE_HOURS=24

# Optional: Only process emails from these domains (comma-separated)
# EMAIL_ALLOWED_DOMAINS=example.com,company.org

# Optional: Block emails from these domains (comma-separated)
# EMAIL_BLOCKED_DOMAINS=spam.com,newsletter.net

# Optional: Block emails from specific senders (comma-separated)
# EMAIL_BLOCKED_SENDERS=noreply@spam.com,updates@annoying.net

# Optional: Block emails matching subject patterns (regex, comma-separated)
# Example: Block all emails with "unsubscribe" or starting with "Newsletter:"
# EMAIL_SUBJECT_BLOCKLIST=/unsubscribe/i,/^Newsletter:/

# KG-Gen Configuration
KG_GEN_INPUT_DIR=./data/emails
KG_GEN_OUTPUT_DIR=./data/graphs
KG_GEN_MODEL=gemma3:4b
KG_GEN_HOST=http://localhost:11434
KG_GEN_WATCH_ENABLED=true

# Logger
LOG_LEVEL=info
