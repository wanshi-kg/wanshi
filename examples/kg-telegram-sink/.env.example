# Copy to .env and fill in. .env is gitignored.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Comma-separated numeric Telegram user IDs allowed to use the bot.
# Get yours from @userinfobot. Leave empty to allow everyone (NOT recommended).
TELEGRAM_ALLOWED_USER_IDS=111111111

# API key for the OpenAI-compatible generation provider (config.yaml -> llm.host/model).
# kg-gen reads OPENAI_API_KEY or KG_API_KEY automatically.
OPENAI_API_KEY=sk-or-...

# Optional: override the kg-gen config file path (default ./config.yaml)
# KG_CONFIG_PATH=./config.yaml
